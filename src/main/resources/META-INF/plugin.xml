<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.reonaore.fuzzyfinderintellijplugin</id>
    <name>Fuzzy Finder</name>
    <vendor>reonaore</vendor>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Fuzzy Finder Notifications" displayType="BALLOON" />
        <applicationConfigurable
                parentId="tools"
                instance="com.github.reonaore.fuzzyfinderintellijplugin.settings.FuzzyFinderSettingsConfigurable"
                id="com.github.reonaore.fuzzyfinderintellijplugin.settings"
                displayName="Fuzzy Finder" />
    </extensions>

    <actions>
        <action
                id="com.github.reonaore.fuzzyfinderintellijplugin.filefinder.OpenFuzzyFinderAction"
                class="com.github.reonaore.fuzzyfinderintellijplugin.filefinder.OpenFuzzyFinderAction"
                text="Open Fuzzy Finder"
                description="Search project files with fd and fzf">
            <add-to-group group-id="ToolsMenu" anchor="last" />
        </action>
        <action
                id="com.github.reonaore.fuzzyfinderintellijplugin.livegrep.OpenLiveGrepAction"
                class="com.github.reonaore.fuzzyfinderintellijplugin.livegrep.OpenLiveGrepAction"
                text="Open Live Grep"
                description="Search project text with rg">
            <add-to-group group-id="ToolsMenu" anchor="last" />
        </action>
    </actions>
</idea-plugin>
